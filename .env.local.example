# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_...       # From Clerk Dashboard → Webhooks

# Database
DATABASE_URL=postgresql://...

# Inngest
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# E2B
E2B_API_KEY=...

# App URL (used for GitHub webhook registration)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Vercel (optional — auto-deploy on every GitHub push) ────────────────────
# Get from: vercel.com → Account Settings → Tokens → Create token
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 'true' once VERCEL_TOKEN is configured
NEXT_PUBLIC_VERCEL_ENABLED=false



# ── Clerk (Auth & Billing) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=        # clerk.com → API Keys
CLERK_SECRET_KEY=                         # clerk.com → API Keys
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=                     # clerk.com → Webhooks → user webhook → Signing secret
CLERK_BILLING_WEBHOOK_SECRET=             # clerk.com → Webhooks → billing webhook → Signing secret

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=                             # neon.tech → New project → Connection string

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=             # aistudio.google.com → Get API Key

# ── E2B (Sandbox previews) ───────────────────────────────────────────────────
E2B_API_KEY=                              # e2b.dev → Dashboard → API Keys

# ── Inngest (AI agent queue) ──────────────────────────────────────────────────
INNGEST_EVENT_KEY=                        # inngest.com → App → Event Key
INNGEST_SIGNING_KEY=                      # inngest.com → App → Signing Key

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                      # http://localhost:3000 (local) or https://your-app.vercel.app (prod)
NEXT_PUBLIC_API_URL=                      # Same as APP_URL

# ── Vercel (Auto-deploy) — optional ──────────────────────────────────────────
VERCEL_TOKEN=                             # vercel.com → Account Settings → Tokens (Full Access)
NEXT_PUBLIC_VERCEL_ENABLED=false          # Set to true once VERCEL_TOKEN is set

# ── Supabase (DB provisioning per project) — optional ────────────────────────
SUPABASE_ACCESS_TOKEN=                    # supabase.com → Account → Access Tokens
SUPABASE_ORGANIZATION_ID=                 # supabase.com → Account → Organizations → copy ID
SUPABASE_SERVICE_ROLE_KEY=                # supabase.com → Project Settings → API → service_role key

# ── Figma (Design import) — optional ─────────────────────────────────────────
FIGMA_ACCESS_TOKEN=                       # figma.com → Account Settings → Personal access tokens
FIGMA_FILE_KEY=                           # figma.com/file/[THIS_PART]/your-file-name

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=                           # resend.com → API Keys → Create API Key
ADMIN_EMAIL=                              # Your email — receives feedback alerts

# ── Admin Dashboard ───────────────────────────────────────────────────────────
ADMIN_USER_IDS=                           # Your Clerk user ID (user_2abc123...) — comma-separate for multiple

# ── OpenRouter (Optional model swap — disabled by default) ───────────────────
OPENROUTER_API_KEY=                       # openrouter.ai → Dashboard → API Keys

# ── Sentry (Error monitoring) ────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                   # sentry.io → New Project → Next.js → DSN
SENTRY_AUTH_TOKEN=                        # sentry.io → Settings → Auth Tokens
SENTRY_ORG=                              # Your Sentry org slug
SENTRY_PROJECT=luno                       # Your Sentry project slug