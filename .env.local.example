# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_...       # From Clerk Dashboard → Webhooks

# Database
DATABASE_URL=postgresql://...

# Inngest
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# E2B
E2B_API_KEY=...

# App URL (used for GitHub webhook registration)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Vercel (optional — auto-deploy on every GitHub push) ────────────────────
# Get from: vercel.com → Account Settings → Tokens → Create token
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set to 'true' once VERCEL_TOKEN is configured
NEXT_PUBLIC_VERCEL_ENABLED=false
