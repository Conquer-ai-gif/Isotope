generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Workspace (team container) ──────────────────────────────────────────────
model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String // Clerk userId — credits are consumed from this user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  Member[]
  projects Project[]
  invites  Invite[]
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Member {
  id          String     @id @default(uuid())
  workspaceId String
  userId      String // Clerk userId
  role        MemberRole @default(EDITOR)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Invite {
  id          String     @id @default(uuid())
  workspaceId String
  role        MemberRole @default(EDITOR)
  token       String     @unique @default(uuid())
  createdAt   DateTime   @default(now())
  expiresAt   DateTime // 7 days from creation
  acceptedAt  DateTime?
  acceptedBy  String? // Clerk userId who accepted

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ── Project ─────────────────────────────────────────────────────────────────
model Project {
  id        String   @id @default(uuid())
  name      String
  userId    String // creator — always set, even for workspace projects
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Team collaboration — null for personal projects
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  repoOwner         String?
  repoName          String?
  repoWebhookId     Int?
  repoWebhookSecret String?
  lastSyncedAt      DateTime?

  vercelProjectId String?
  vercelDeployUrl String?
  customDomain    String?

  supabaseProjectId String?
  supabaseUrl       String?
  supabaseAnonKey   String?

  contextDocument String? // Brand/rules injected into every prompt
  hideBadge       Boolean @default(false) // Pro: hide "Built with Luno" badge

  // Persistent E2B sandbox — reused across all generations for this project
  sandboxId String?

  messages      Message[]
  syncConflicts SyncConflict[]
  tasks         Task[]
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  RESULT
  ERROR
}

enum PlanStatus {
  pending
  approved
  rejected
}

model Message {
  id         String      @id @default(uuid())
  content    String
  role       MessageRole
  type       MessageType
  imageUrl   String?
  plan       String? // JSON plan generated before code execution
  planStatus PlanStatus? // pending | approved | rejected
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fragment  Fragment?
}

model Fragment {
  id        String  @id @default(uuid())
  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  sandboxUrl   String
  title        String
  files        Json
  deployUrl    String?
  branchName   String? // Git branch created for this generation e.g. luno/add-dark-mode-abc123
  branchMerged Boolean @default(false) // Whether branch has been merged to main

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Credit system ────────────────────────────────────────────────────────────

enum Plan {
  free
  pro
  team
}

enum CreditEventReason {
  signup
  monthly_reset
  generation
  referral
  plan_upgrade
  plan_renewal
}

model Credits {
  userId    String   @id // Clerk userId
  balance   Int      @default(5)
  plan      Plan     @default(free)
  lastReset DateTime @default(now())
  nextReset DateTime // set to createdAt + 30 days on signup
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CreditEvent[]
}

model CreditEvent {
  id        String            @id @default(uuid())
  userId    String
  delta     Int // positive = earned, negative = spent
  reason    CreditEventReason
  createdAt DateTime          @default(now())

  credits Credits @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model GitHubToken {
  id          String   @id @default(uuid())
  userId      String   @unique
  accessToken String
  login       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncConflict {
  id             String   @id @default(uuid())
  projectId      String
  filePath       String
  isotopeContent String
  githubContent  String
  resolvedBy     String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── Feedback ─────────────────────────────────────────────────────────────────

enum FeedbackType {
  general
  bug
  feature
}

enum FeedbackStatus {
  new
  reviewed
  resolved
}

model Feedback {
  id        String         @id @default(uuid())
  userId    String? // Clerk userId — null if unauthenticated
  type      FeedbackType   @default(general)
  rating    Int? // 1–5 star rating, optional
  message   String
  status    FeedbackStatus @default(new)
  createdAt DateTime       @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Marketplace templates ─────────────────────────────────────────────────────

model MarketplaceTemplate {
  id          String   @id @default(uuid())
  projectId   String? // source project (nullable — official templates have no project)
  userId      String // Clerk userId of author
  title       String
  description String
  prompt      String
  category    String
  emoji       String   @default("🚀")
  files       Json // snapshot of generated files
  useCount    Int      @default(0)
  likeCount   Int      @default(0)
  featured    Boolean  @default(false)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  likes TemplateLike[]

  @@index([category])
  @@index([featured])
  @@index([useCount])
  @@index([createdAt])
}

model TemplateLike {
  id         String   @id @default(uuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())

  template MarketplaceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

// ── Referral program ─────────────────────────────────────────────────────────
model Referral {
  id        String   @id @default(uuid())
  code      String   @unique // e.g. "abc123" — the referrer's invite code
  ownerId   String   @unique // Clerk userId who owns this code
  createdAt DateTime @default(now())

  uses ReferralUse[]
}

model ReferralUse {
  id         String   @id @default(uuid())
  referralId String
  newUserId  String   @unique // the person who signed up with the code
  createdAt  DateTime @default(now())

  referral Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
}

// ── Changelog ─────────────────────────────────────────────────────────────────

enum ChangelogType {
  feature
  improvement
  bugfix
  breaking
}

model ChangelogEntry {
  id          String        @id @default(uuid())
  title       String
  content     String
  type        ChangelogType @default(feature)
  tags        String[]
  published   Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([published])
  @@index([publishedAt])
}

model ChangelogSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

// ── Generation event stream ───────────────────────────────────────────────────
// Written by the Inngest function; polled by /api/generation/stream SSE endpoint.

model GenerationEvent {
  seq       Int      @id @default(autoincrement())
  messageId String
  type      String
  taskId    String?
  data      Json?    @default("{}")
  createdAt DateTime @default(now())

  @@index([messageId])
}

// ── Task board ────────────────────────────────────────────────────────────────

enum TaskStatus {
  todo
  in_progress
  in_review
  done
}

enum TaskPriority {
  low
  medium
  high
}

model Task {
  id          String       @id @default(uuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  labels      String[]
  order       Int          @default(0)
  createdBy   String // Clerk userId
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}
